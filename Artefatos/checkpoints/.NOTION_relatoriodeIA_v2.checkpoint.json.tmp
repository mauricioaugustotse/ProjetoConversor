        "AIJE"
      ],
      "partes": [
        "ALISON ANDREI PEREIRA DE CAMARGO",
        "COLIGAÇÃO EU ESCOLHO VOTORANTIM",
        "FABIOLA ALVES DA SILVA"
      ],
      "partidos": [],
