        "TERESA CRISTINA AGUIAR TOFANELLO WIAZOWSKI"
      ],
      "partidos": [],
      "relator": "Min. André Mendonça",
      "advogados": [
        "RUI FRANCO PERES JUNIOR",
        "DANILO AUGUSTO RUIVO",
        "ELIABE DONIZETE ELIAS",
        "RENATO CARVALHO DONATO",
        "Ricardo Vita Porto",
        "Guilherme Giometti Santinho",
