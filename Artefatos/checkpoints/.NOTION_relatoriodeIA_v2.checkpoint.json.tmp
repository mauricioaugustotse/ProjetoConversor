        "Fundo Partidário"
      ],
      "partes": [
        "ELANI TAIZA DE ARAUJO",
        "JOSE ANTONIO RODRIGUES DE OLIVEIRA",
        "PARTIDO SOCIALISTA BRASILEIRO (PSB) - MUNICIPAL"
      ],
      "partidos": [
        "PSB/PB"
      ],
      "relator": "Min. André Mendonça",
      "advogados": [
