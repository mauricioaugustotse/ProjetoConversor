    {
      "case_id": "0600599-24.2024.6.26.0386",
      "page_id": "32872195-5c64-81b9-9bab-d3b8dac26653",
      "source_url": "https://www.notion.so/328721955c6481b99babd3b8dac26653",
      "data_decisao": "2026-02-02",
      "numero_unico": "0600599-24.2024.6.26.0386",
      "numero_processo": "60059924",
      "ano_eleicao": "2024",
      "sigla_classe": "AREspEl",
