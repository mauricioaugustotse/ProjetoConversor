      "source_url": "https://www.notion.so/328721955c648094aad7d5e9d9156d29",
      "data_decisao": "2026-02-05",
      "numero_unico": "0600102-46.2025.6.16.0000",
      "numero_processo": "60010246",
      "ano_eleicao": "2022",
      "sigla_classe": "RO-El",
      "descricao_classe": "RECURSO ORDINáRIO ELEITORAL",
      "sigla_uf": "PR",
      "nome_municipio": "CURITIBA",
      "descricao_tipo_decisao": "Decisão monocrática",
      "assuntos": [
