      ],
      "partes": [
        "JAIRO TAMURA",
        "OGIER ALBERGE BUCHI",
        "PARTIDO LIBERAL (PL) - ESTADUAL",
        "ROMULO QUINTINO"
      ],
      "partidos": [
        "PL/PR"
      ],
      "relator": "Min. Floriano De Azevedo Marques",
      "advogados": [
        "Ogier Alberge Buchi",
        "Luiz Fernando Casagrande Pereira",
        "Fabrício de Mello Marsango",
