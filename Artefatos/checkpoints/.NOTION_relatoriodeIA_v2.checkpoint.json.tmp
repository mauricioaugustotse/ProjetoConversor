      "assuntos": [
        "AIJE",
        "Abuso de poder"
      ],
      "partes": [
        "COLIGAÇÃO UNIÃO E PROGRESSO",
        "EUSEBIO FERREIRA DA SILVA",
        "MARIA AUXILIADORA DE SOUSA MOURA",
        "MARIA FURTADO DE LUCENA"
      ],
      "partidos": [],
