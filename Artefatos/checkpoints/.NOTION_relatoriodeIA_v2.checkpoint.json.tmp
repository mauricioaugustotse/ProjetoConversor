      "numero_processo": "60424316",
      "ano_eleicao": "",
      "sigla_classe": "AREspEl",
      "descricao_classe": "Agravo em Recurso Especial Eleitoral",
      "sigla_uf": "PR",
      "nome_municipio": "CURITIBA",
      "descricao_tipo_decisao": "Acórdão",
      "assuntos": [
        "Contas de exercício financeiro"
      ],
      "partes": [
        "MOVIMENTO DEMOCRATICO BRASILEIRO (MDB) - ESTADUAL",
