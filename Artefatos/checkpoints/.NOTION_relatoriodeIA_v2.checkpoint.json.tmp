      "numero_unico": "0601517-05.2022.6.04.0000",
      "numero_processo": "60151705",
      "ano_eleicao": "2022",
      "sigla_classe": "REspEl",
      "descricao_classe": "RECURSO ESPECIAL ELEITORAL",
      "sigla_uf": "AM",
      "nome_municipio": "MANAUS",
      "descricao_tipo_decisao": "Acórdão",
      "assuntos": [
