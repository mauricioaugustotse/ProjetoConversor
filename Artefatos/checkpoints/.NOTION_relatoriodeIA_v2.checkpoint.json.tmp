      "numero_unico": "0600604-51.2024.6.05.0153",
      "numero_processo": "60060451",
      "ano_eleicao": "2024",
      "sigla_classe": "AREspEl",
      "descricao_classe": "Agravo em Recurso Especial Eleitoral",
      "sigla_uf": "BA",
