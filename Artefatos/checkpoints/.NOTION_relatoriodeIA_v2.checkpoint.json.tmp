      ],
      "partes": [
        "KASSYO SANTOS RAMOS",
        "LEIVO RODRIGUES DOS SANTOS",
        "Ministério Público Eleitoral",
        "PARTIDO RENOVAÇÃO DEMOCRÁTICA (PRD) - MUNICIPAL"
      ],
