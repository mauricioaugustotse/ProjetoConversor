      "relator": "Min. André Mendonça",
      "advogados": [
        "THIAGO ARAUJO MONTEZUMA",
        "JOAO DE AGUIAR PUPO",
        "FRANCISCO DIEGO POTE DE HOLANDA DO NASCIMENTO",
        "JOAQUIM LUCIO MELO FREITAS",
        "RODRIGO CARVALHO ARRUDA BARRETO",
        "GUSTAVO JUDHAR FERREIRA RIBEIRO",
