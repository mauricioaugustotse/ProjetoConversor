    {
      "case_id": "0601450-45.2022.6.11.0000",
      "page_id": "32872195-5c64-8057-9d34-dca3a4a3068b",
      "source_url": "https://www.notion.so/328721955c6480579d34dca3a4a3068b",
      "data_decisao": "2026-02-05",
      "numero_unico": "0601450-45.2022.6.11.0000",
      "numero_processo": "60145045",
      "ano_eleicao": "2022",
      "sigla_classe": "AREspEl",
      "descricao_classe": "Agravo em Recurso Especial Eleitoral",
      "sigla_uf": "MT",
      "nome_municipio": "CUIABÁ",
      "descricao_tipo_decisao": "Acórdão",
