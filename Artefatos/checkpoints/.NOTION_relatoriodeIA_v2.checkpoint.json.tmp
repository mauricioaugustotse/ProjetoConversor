    {
      "case_id": "0600942-21.2020.6.13.0160",
      "page_id": "32872195-5c64-80c5-99f2-c296b79d5cf0",
      "source_url": "https://www.notion.so/328721955c6480c599f2c296b79d5cf0",
      "data_decisao": "2026-02-05",
      "numero_unico": "0600942-21.2020.6.13.0160",
      "numero_processo": "60094221",
      "ano_eleicao": "2020",
      "sigla_classe": "AREspEl",
      "descricao_classe": "Agravo em Recurso Especial Eleitoral",
      "sigla_uf": "MG",
      "nome_municipio": "LAVRAS",
      "descricao_tipo_decisao": "Decisão monocrática",
      "assuntos": [
        "AIJE",
