      "numero_unico": "0603374-59.2022.6.05.0000",
      "numero_processo": "60337459",
      "ano_eleicao": "2022",
      "sigla_classe": "AREspEl",
      "descricao_classe": "Agravo em Recurso Especial Eleitoral",
      "sigla_uf": "BA",
      "nome_municipio": "SALVADOR",
      "descricao_tipo_decisao": "Acórdão",
      "assuntos": [
        "Contas de campanha"
      ],
      "partes": [
        "VALDERICO LUIZ DOS REIS JUNIOR"
      ],
      "partidos": [],
      "relator": "Min. Cármen Lúcia",
