      ],
      "partes": [
        "COLIGAÇÃO O FUTURO É PRA JÁ",
        "IRAJA SILVESTRE FILHO",
        "LAUREZ DA ROCHA MOREIRA",
        "WANDERLEI BARBOSA CASTRO"
      ],
      "partidos": [],
