      "numero_unico": "0600354-26.2024.6.26.0220",
      "numero_processo": "60035426",
      "ano_eleicao": "2024",
      "sigla_classe": "AREspEl",
      "descricao_classe": "Agravo em Recurso Especial Eleitoral",
      "sigla_uf": "SP",
      "nome_municipio": "VOTORANTIM",
      "descricao_tipo_decisao": "Decisão monocrática",
      "assuntos": [
