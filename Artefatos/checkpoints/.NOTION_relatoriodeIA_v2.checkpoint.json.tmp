      ],
      "partes": [
        "ANDREA ANGELITA LISBOA",
        "FEDERAÇÃO PSDB CIDADANIA (PSDB/CIDADANIA) - APIAI / SP",
        "JOAO PAULO PEREIRA DE OLIVEIRA PEDROSO",
        "PODEMOS (PODE) MUNICIPAL",
        "RITA DE CASSIA OLIVEIRA SANTIAGO"
      ],
      "partidos": [
