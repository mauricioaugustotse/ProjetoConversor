      "assuntos": [
        "Matéria processual",
        "Propaganda eleitoral irregular"
      ],
      "partes": [
        "ANDREIA DOS SANTOS MOREIRA",
        "COLIGAÇÃO BARUERI NÃO PODE PARAR",
        "FABIANO ANDRADE FURLAN",
        "GIDELSON ALVES",
        "NATHALIA NOGUEIRA TRUGILLO ARANTES",
