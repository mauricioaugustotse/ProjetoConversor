        "JONATHA GIBSON SANTOS DE OLIVEIRA",
        "MICHAEL BARBOSA MENINO",
        "MOVIMENTO DEMOCRATICO BRASILEIRO (MDB) - MUNICIPAL",
        "REGINALDO PINTO DE OLIVEIRA",
        "REPUBLICANOS (REPUBLICANOS) - MUNICIPAL",
        "RODRIGO DA COSTA DO NASCIMENTO",
        "UNIAO BRASIL (UNIÃO) - MUNICIPAL"
      ],
      "partidos": [
        "MDB/MG",
